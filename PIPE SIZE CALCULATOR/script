def fu_to_lps(fu, table):
    keys = sorted(table.keys())
    if fu <= keys[0]:  return table[keys[0]]
    if fu >= keys[-1]: return table[keys[-1]]
    for i in range(len(keys)-1):
        k1, k2 = keys[i], keys[i+1]
        if k1 <= fu <= k2:
            ratio = float(fu-k1)/float(k2-k1)
            return table[k1] + ratio*(table[k2]-table[k1])
    return 0


