def lps_to_pipe(lps, table):
    for low, high, size in table:
        if low <= lps < high:
            return size
    return table[-1][2]


# ---------------- COLUMN LAYOUT ---------------- #
COL_FIXTURE =  15
COL_COLD_FU = 300
COL_HOT_FU  = 365
COL_QTY     = 430
COL_W       =  60
COL_QTY_W   =  60

# ---------------- FORM ---------------- #
 
class PipeCalculatorForm(Form):
 
    def __init__(self):
        self.Text   = "Water Supply Pipe Size Calculator"
        self.Width  = 560
        self.Height = 800
 
        # ------ Dropdown at top ------ #
        lbl_type          = Label()
        lbl_type.Text     = "SUPPLY SYSTEM:"
        lbl_type.Location = Point(15, 15)
        lbl_type.Width    = 160
        lbl_type.Height   = 22
        lbl_type.Font     = Font("Arial", 9, System.Drawing.FontStyle.Bold)
        self.Controls.Add(lbl_type)

        self.combo               = ComboBox()
        self.combo.Location      = Point(175, 12)
        self.combo.Width         = 160
        self.combo.Height        = 24
        self.combo.DropDownStyle = ComboBoxStyle.DropDownList
        self.combo.Items.Add("Flush Tank")
        self.combo.Items.Add("Flush Valve")
        self.combo.SelectedIndex = 0
        self.Controls.Add(self.combo)

        # ------ Scrollable panel below dropdown ------ #
        panel = Panel()
        panel.Location   = Point(0, 45)
        panel.Size       = Size(560, 680)
        panel.AutoScroll = True
        self.Controls.Add(panel)
 
        self.inputs = {}
        bold_font  = Font("Arial", 8, System.Drawing.FontStyle.Bold)
        gray_color = Color.FromArgb(80, 80, 80)

        # ------ Header row ------ #
        y = 10

        def make_header(text, x, w):
            lbl           = Label()
            lbl.Text      = text
            lbl.Location  = Point(x, y)
            lbl.Width     = w
            lbl.Height    = 20
            lbl.Font      = bold_font
            lbl.ForeColor = Color.DarkSlateGray
            panel.Controls.Add(lbl)

        make_header("Fixture",   COL_FIXTURE, 280)
        make_header("Cold FU",   COL_COLD_FU, COL_W)
        make_header("Hot FU",    COL_HOT_FU,  COL_W)
        make_header("Qty",       COL_QTY,     COL_QTY_W)

        y += 24

        # ------ Fixture rows ------ #
        for fixture in FIXTURE_ORDER:
            cold_fu, hot_fu = IPC_VALUES[fixture]

            lbl_fix           = Label()
            lbl_fix.Text      = fixture
            lbl_fix.Location  = Point(COL_FIXTURE, y)
            lbl_fix.Width     = 280
            lbl_fix.Height    = 22
            panel.Controls.Add(lbl_fix)

            lbl_cold           = Label()
            lbl_cold.Text      = str(cold_fu)
            lbl_cold.Location  = Point(COL_COLD_FU, y)
            lbl_cold.Width     = COL_W
            lbl_cold.Height    = 22
            lbl_cold.ForeColor = gray_color
            panel.Controls.Add(lbl_cold)

            lbl_hot            = Label()
            lbl_hot.Text       = str(hot_fu)
            lbl_hot.Location   = Point(COL_HOT_FU, y)
            lbl_hot.Width      = COL_W
            lbl_hot.Height     = 22
            lbl_hot.ForeColor  = gray_color
            panel.Controls.Add(lbl_hot)

            txt          = TextBox()
            txt.Text     = ""
            txt.Location = Point(COL_QTY, y)
            txt.Width    = COL_QTY_W
            panel.Controls.Add(txt)

            self.inputs[fixture] = txt
            y += 28

        # ------ Calculate button ------ #
        btn          = Button()
        btn.Text     = "Calculate"
        btn.Location = Point(COL_FIXTURE, y + 10)
        btn.Width    = 120
        btn.Height   = 30
        btn.Click   += self.on_calculate
        panel.Controls.Add(btn)

        # ------ Result label ------ #
        self.result           = Label()
        self.result.Location  = Point(COL_FIXTURE, y + 55)
        self.result.Width     = 500
        self.result.Height    = 80
        self.result.Font      = Font("Arial", 10, System.Drawing.FontStyle.Bold)
        self.result.ForeColor = Color.DarkBlue
        panel.Controls.Add(self.result)
 
    def on_calculate(self, sender, args):
        try:
            selected = self.combo.SelectedItem.ToString()
            if selected == "Flush Valve":
                fu_table = FU_TO_LPS_FLUSH_VALVE
            else:
                fu_table = FU_TO_LPS_FLUSH_TANK

            cold_fu = 0.0
            hot_fu  = 0.0
 
            for fixture, box in self.inputs.items():
                raw = box.Text.strip()
                qty = float(raw) if raw else 0.0
                c, h = IPC_VALUES[fixture]
                cold_fu += float(c) * qty
                hot_fu  += float(h) * qty
 
            cold_lps  = float(fu_to_lps(cold_fu, fu_table))
            hot_lps   = float(fu_to_lps(hot_fu,  fu_table))
            cold_pipe = int(lps_to_pipe(cold_lps, COLD_PIPE))
            hot_pipe  = int(lps_to_pipe(hot_lps,  HOT_PIPE))

            self.result.Text = (
                "Cold Water Pipe Size : {0} mm  ({1:.3f} L/s)   FU: {2:.2f}\n"
                "Hot Water Pipe Size  : {3} mm  ({4:.3f} L/s)   FU: {5:.2f}"
            ).format(cold_pipe, cold_lps, float(cold_fu),
                     hot_pipe,  hot_lps,  float(hot_fu))
 
        except Exception as ex:
            pyforms.alert("Calculation error:\n" + str(ex))
 
 
